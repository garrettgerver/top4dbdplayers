PORT=3000
# This can be a normal local folder or a mounted NAS path, e.g. /mnt/nas/hls-videos
STORAGE_ROOT=./storage
DB_PATH=./data/videos.sqlite
# 0 = VOD manifest includes all segments. 6 = your original sliding-window example.
HLS_LIST_SIZE=0
# Optional: frontend origin, e.g. http://localhost:5173. Use * during local dev only.
CORS_ORIGIN=*
